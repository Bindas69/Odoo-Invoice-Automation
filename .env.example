# ============================================
# ODOO CONFIGURATION
# ============================================
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_db
ODOO_USERNAME=admin
ODOO_PASSWORD=your_admin_password_here
ODOO_ADMIN_PORT=8069

# ============================================
# TWILIO CONFIGURATION (WhatsApp)
# ============================================
# Get these from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_SID=PNxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio WhatsApp sender number (with country code)
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# Webhook URL for Twilio callbacks (for production only)
TWILIO_WEBHOOK_URL=https://your-production-domain.com/webhooks/twilio

# ============================================
# n8n CONFIGURATION
# ============================================
N8N_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key_here
N8N_LOG_LEVEL=info
N8N_EXECUTION_TIMEOUT=600

# n8n database (if using PostgreSQL backend for n8n)
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_DATABASE=n8n_db
N8N_DB_POSTGRESDB_HOST=localhost
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_USER=odoo
N8N_DB_POSTGRESDB_PASSWORD=odoopass123

# ============================================
# POSTGRESQL CONFIGURATION (Audit Logging)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=odoo
DB_PASSWORD=odoopass123
DB_NAME=invoice_automation_logs
DB_SSL=false

# ============================================
# WORKFLOW CONFIGURATION
# ============================================
# How often to check for new invoices (in minutes)
INVOICE_CHECK_INTERVAL=5

# Maximum number of parallel invoice processing
MAX_PARALLEL_INVOICES=10

# Retry failed WhatsApp sends (max attempts)
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_SECONDS=30

# Filter invoices (optional)
# Leave empty to process all invoices
INVOICE_FILTER_CUSTOMER_ID=
INVOICE_FILTER_MIN_AMOUNT=0
INVOICE_FILTER_MAX_AMOUNT=999999

# ============================================
# EMAIL NOTIFICATIONS (for errors)
# ============================================
ADMIN_EMAIL=admin@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_ADDRESS=noreply@yourdomain.com

# ============================================
# LOGGING & MONITORING
# ============================================
# Enable detailed logging
DEBUG_MODE=false

# Log file location
LOG_FILE_PATH=./logs/workflow.log

# Sentry error tracking (optional)
SENTRY_DSN=https://your_sentry_url@sentry.io/xxxxx

# ============================================
# DEPLOYMENT (Production Only)
# ============================================
NODE_ENV=development
# Change to 'production' for live deployment

DEPLOYMENT_URL=http://localhost:5678
DEPLOYMENT_PORT=5678

# SSL Certificate paths (if using HTTPS)
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem
